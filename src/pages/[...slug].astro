---
import { getCollection } from "astro:content";
import ItemList from "../components/ItemList.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((entry) => {
    // `index` maps to the site root ("/").
    const slug = entry.id.replace(/index$/, "");
    return {
      params: { slug: slug.length ? slug : undefined },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const blocks = entry.data.content_blocks ?? [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{entry.data.title}</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 40rem;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      li { margin: 0.5rem 0; }
      code { color: #666; font-size: 0.8em; margin-left: 0.5rem; }
    </style>
  </head>
  <body>
    <script>
      // CloudCannon Visual Editor only: register components so CC can re-render
      // them from data. (Base [data-editable] hydration is injected by CC.)
      if (window?.inEditorMode) {
        import("../scripts/register-components.ts");
      }
    </script>

    <main>
      <h1>{entry.data.title}</h1>
      <p>
        The list lives inside a <strong>registered component</strong>
        (<code>item-list</code>), placed via a page-builder
        <code>content_blocks</code> array — the same way the real testimonial
        component (which exhibits the bug) is wrapped. Each item's
        <code>data-ns-bound</code> is <strong>computed markup</strong>, not its
        own editable region, so it only updates when the parent component
        re-renders. Add / reorder items and watch whether
        <code>data-ns-bound</code> tracks each item's real <code>_uuid</code>.
      </p>

      <!--
        Page-builder array of components. The only block type is `item-list`.
        - data-component-key="_name": which field names the component type
        - data-id-key="_name": stable id field for matching DOM <-> data
        The INNER `items` array (inside ItemList) is the one under test.
      -->
      <div
        data-editable="array"
        data-prop="content_blocks"
        data-component-key="_name"
        data-id-key="_name"
      >
        {
          blocks.map((block) => (
            <editable-array-item data-component={block._name} data-id={block._name}>
              <editable-component data-component={block._name} data-prop="">
                {block._name === "item-list" && <ItemList items={block.items} />}
              </editable-component>
            </editable-array-item>
          ))
        }
      </div>
    </main>
  </body>
</html>
