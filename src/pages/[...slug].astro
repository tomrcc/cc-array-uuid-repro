---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((entry) => {
    // `index` maps to the site root ("/"), everything else to "/<id>/".
    const slug = entry.id.replace(/index$/, "");
    return {
      params: { slug: slug.length ? slug : undefined },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const items = entry.data.items ?? [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{entry.data.title}</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 40rem;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      li {
        margin: 0.5rem 0;
      }
      code {
        color: #666;
        font-size: 0.8em;
        margin-left: 0.5rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>{entry.data.title}</h1>
      <p>
        Add an item to the list in the Visual Editor, and inspect in the dev
        tools. As array items are dragged around they should be taking their
        uuids with them, but they appear to stay in place.
      </p>
      <ul>
        <li>
          <code>data-ns-build</code> — set <strong>only at build time</strong>
          (<code>={"{item._uuid}"}</code>), no binding.
        </li>
        <li>
          <code>data-ns-bound</code> — set <strong> via the binding</strong>
          (<code>data-prop-data-ns-bound="_uuid"</code>), and a build-time
          value.
        </li>
      </ul>

      <!--
        Editable array bound to the current file's `items` frontmatter.
        Two independent attributes per item:
          - data-ns-build={item._uuid}          build-time only
          - data-prop-data-ns-bound="_uuid"      binding only (sets data-ns-bound)
        So on a newly-added item we can see, separately:
          * does the build-time attr get the new uuid?  (expect: no — stale clone)
          * does the data-prop binding stamp data-ns-bound with the new uuid?
            (the data-prop-* question — also check whether it stamps existing items at all)
      -->
      <ul data-editable="array" data-prop="items">
        {
          items.map((item) => (
            <li data-editable="array-item" data-ns-bound={item._uuid}>
              <span data-editable="text" data-prop="label">
                {item.label}
              </span>
              <code>(_uuid: {item._uuid})</code>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>
